import serial
import time
import curses
import RPi.GPIO as GPIO

PORT = "/dev/ttyUSB0"   # change to "/dev/ttyACM0" if needed
BAUD = 57600

TRIG = 23
ECHO = 24

MAX_SPEED = 220
TURN_SPEED = 130
CURVE_AMOUNT = 0.45

ACCEL = 14
DECEL = 45
LOOP_TIME = 0.04

STOP_DISTANCE_CM = 10
WARNING_DISTANCE_CM = 20

ser = serial.Serial(PORT, BAUD, timeout=1)
time.sleep(1)

GPIO.setmode(GPIO.BCM)
GPIO.setup(TRIG, GPIO.OUT)
GPIO.setup(ECHO, GPIO.IN)
GPIO.output(TRIG, False)
time.sleep(0.5)

def signed_16(value):
    value = int(max(min(value, 500), -500))
    if value < 0:
        value = 65536 + value
    return [(value >> 8) & 255, value & 255]

def drive_direct(left, right):
    rb = signed_16(right)
    lb = signed_16(left)
    ser.write(bytes([145] + rb + lb))

def stop_robot():
    drive_direct(0, 0)

def ramp(current, target):
    step = ACCEL if abs(target) > abs(current) else DECEL
    if current < target:
        return min(current + step, target)
    elif current > target:
        return max(current - step, target)
    return current

def single_distance_cm():
    GPIO.output(TRIG, False)
    time.sleep(0.00002)

    GPIO.output(TRIG, True)
    time.sleep(0.00001)
    GPIO.output(TRIG, False)

    timeout = time.time() + 0.03
    while GPIO.input(ECHO) == 0:
        pulse_start = time.time()
        if time.time() > timeout:
            return None

    timeout = time.time() + 0.03
    while GPIO.input(ECHO) == 1:
        pulse_end = time.time()
        if time.time() > timeout:
            return None

    duration = pulse_end - pulse_start
    distance = duration * 17150

    if distance < 2 or distance > 400:
        return None

    return round(distance, 1)

def get_distance_cm():
    readings = []

    for _ in range(5):
        d = single_distance_cm()
        if d is not None:
            readings.append(d)
        time.sleep(0.01)

    if len(readings) == 0:
        return None

    readings.sort()
    return readings[len(readings) // 2]

def main(screen):
    current_left = 0
    current_right = 0
    distance = None

    curses.curs_set(0)
    screen.nodelay(True)
    screen.keypad(True)

    ser.write(bytes([128]))
    time.sleep(0.1)
    ser.write(bytes([132]))
    time.sleep(0.1)

    pressed = set()
    last_key_time = time.time()
    last_distance_time = 0

    try:
        while True:
            now = time.time()
            key = screen.getch()

            if key != -1:
                last_key_time = now

                if key == curses.KEY_UP:
                    pressed.add("up")
                elif key == curses.KEY_DOWN:
                    pressed.add("down")
                elif key == curses.KEY_LEFT:
                    pressed.add("left")
                elif key == curses.KEY_RIGHT:
                    pressed.add("right")
                elif key == ord(" "):
                    pressed.clear()
                elif key == ord("q") or key == ord("Q"):
                    break

            if now - last_key_time > 0.18:
                pressed.clear()

            if now - last_distance_time > 0.12:
                distance = get_distance_cm()
                last_distance_time = now

            forward = 0

            if "up" in pressed:
                forward = MAX_SPEED
            elif "down" in pressed:
                forward = -MAX_SPEED

            target_left = 0
            target_right = 0

            if forward != 0:
                target_left = forward
                target_right = forward

                if "left" in pressed:
                    target_left = forward * (1 - CURVE_AMOUNT)
                    target_right = forward

                elif "right" in pressed:
                    target_left = forward
                    target_right = forward * (1 - CURVE_AMOUNT)

            else:
                if "left" in pressed:
                    target_left = -TURN_SPEED
                    target_right = TURN_SPEED

                elif "right" in pressed:
                    target_left = TURN_SPEED
                    target_right = -TURN_SPEED

            obstacle_stop = False
            obstacle_warning = False

            if distance is not None:
                if distance <= STOP_DISTANCE_CM:
                    obstacle_stop = True
                elif distance <= WARNING_DISTANCE_CM:
                    obstacle_warning = True

            # Stop only forward motion when object is close
            if obstacle_stop and (target_left > 0 or target_right > 0):
                target_left = 0
                target_right = 0

            target_left = int(max(min(target_left, MAX_SPEED), -MAX_SPEED))
            target_right = int(max(min(target_right, MAX_SPEED), -MAX_SPEED))

            current_left = ramp(current_left, target_left)
            current_right = ramp(current_right, target_right)

            drive_direct(current_left, current_right)

            screen.erase()
            screen.addstr(0, 0, "iRobot Keyboard Drive + Ultrasonic Sensor")
            screen.addstr(2, 0, "UP/DOWN = move | LEFT/RIGHT = turn/curve | SPACE = stop | Q = quit")
            screen.addstr(4, 0, f"Distance: {distance} cm")
            screen.addstr(5, 0, f"Stop distance: {STOP_DISTANCE_CM} cm")
            screen.addstr(6, 0, f"Warning distance: {WARNING_DISTANCE_CM} cm")
            screen.addstr(8, 0, f"Pressed keys: {pressed}")
            screen.addstr(9, 0, f"Target L/R: {target_left:4} {target_right:4}")
            screen.addstr(10, 0, f"Current L/R: {current_left:4} {current_right:4}")

            if distance is None:
                screen.addstr(12, 0, "Sensor status: NO VALID READING")
            elif obstacle_stop:
                screen.addstr(12, 0, "Sensor status: STOP - obstacle too close")
            elif obstacle_warning:
                screen.addstr(12, 0, "Sensor status: WARNING - obstacle nearby")
            else:
                screen.addstr(12, 0, "Sensor status: CLEAR")

            screen.refresh()
            time.sleep(LOOP_TIME)

    finally:
        stop_robot()
        ser.close()
        GPIO.cleanup()

curses.wrapper(main)