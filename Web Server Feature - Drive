from flask import Flask, request
import serial
import time

PORT = "/dev/ttyUSB0"   # change to "/dev/ttyACM0" if needed
BAUD = 57600

MAX_SPEED = 220
TURN_SPEED = 140
CURVE_AMOUNT = 0.45

app = Flask(__name__)

ser = serial.Serial(PORT, BAUD, timeout=1)
time.sleep(1)

def signed_16(value):
    value = int(max(min(value, 500), -500))
    if value < 0:
        value = 65536 + value
    return [(value >> 8) & 255, value & 255]

def drive_direct(left, right):
    right_bytes = signed_16(right)
    left_bytes = signed_16(left)
    ser.write(bytes([145] + right_bytes + left_bytes))

def stop_robot():
    drive_direct(0, 0)

# Start iRobot
ser.write(bytes([128]))
time.sleep(0.1)
ser.write(bytes([132]))
time.sleep(0.1)

