@app.route("/cmd")
def command():
    move = request.args.get("move")

    if move == "forward":
        drive_direct(MAX_SPEED, MAX_SPEED)

    elif move == "backward":
        drive_direct(-MAX_SPEED, -MAX_SPEED)

    elif move == "left":
        drive_direct(-TURN_SPEED, TURN_SPEED)

    elif move == "right":
        drive_direct(TURN_SPEED, -TURN_SPEED)

    elif move == "forward_left":
        drive_direct(int(MAX_SPEED * (1 - CURVE_AMOUNT)), MAX_SPEED)

    elif move == "forward_right":
        drive_direct(MAX_SPEED, int(MAX_SPEED * (1 - CURVE_AMOUNT)))

    elif move == "stop":
        stop_robot()

    return "OK"

if __name__ == "__main__":
    try:
        app.run(host="0.0.0.0", port=5000)
    finally:
        stop_robot()
        ser.close()