from flask import Flask
import serial
import time
import socket
import platform
import os

PORT = "/dev/ttyUSB0"   # Change to "/dev/ttyACM0" if needed
BAUD = 57600

app = Flask(__name__)

robot_connected = False
ser = None

try:
    ser = serial.Serial(PORT, BAUD, timeout=1)
    time.sleep(1)

    ser.write(bytes([128]))  # Start OI
    time.sleep(0.1)
    ser.write(bytes([132]))  # Full mode
    time.sleep(0.1)

    robot_connected = True
except Exception as e:
    robot_connected = False
    serial_error = str(e)


def signed_16(value):
    value = int(max(min(value, 500), -500))
    if value < 0:
        value = 65536 + value
    return [(value >> 8) & 255, value & 255]


def read_sensor(packet_id, size=1):
    if not robot_connected:
        return None

    try:
        ser.write(bytes([142, packet_id]))
        data = ser.read(size)

        if len(data) != size:
            return None

        if size == 1:
            return data[0]

        return int.from_bytes(data, byteorder="big", signed=True)

    except:
        return None


def drive_direct(left, right):
    if not robot_connected:
        return

    rb = signed_16(right)
    lb = signed_16(left)
    ser.write(bytes([145] + rb + lb))


def stop_robot():
    drive_direct(0, 0)


def get_ip():
    try:
        hostname = socket.gethostname()
        return socket.gethostbyname(hostname)
    except:
        return "Unknown"


@app.route("/")
def home():
    bumps = read_sensor(7)
    wall = read_sensor(8)
    cliff_left = read_sensor(9)
    cliff_front_left = read_sensor(10)
    cliff_front_right = read_sensor(11)
    cliff_right = read_sensor(12)
    battery_charge = read_sensor(25, 2)
    battery_capacity = read_sensor(26, 2)
    voltage = read_sensor(22, 2)
    current = read_sensor(23, 2)
    temperature = read_sensor(24)

    battery_percent = "Unknown"
    if battery_charge is not None and battery_capacity not in (None, 0):
        battery_percent = round((battery_charge / battery_capacity) * 100, 1)

    return f"""
