@app.route("/forward")
def forward():
    drive_direct(180, 180)
    return "Forward"


@app.route("/backward")
def backward():
    drive_direct(-180, -180)
    return "Backward"


@app.route("/left")
def left():
    drive_direct(-120, 120)
    return "Left"


@app.route("/right")
def right():
    drive_direct(120, -120)
    return "Right"


@app.route("/stop")
def stop():
    stop_robot()
    return "Stop"


if __name__ == "__main__":
    try:
        app.run(host="0.0.0.0", port=5000)
    finally:
        stop_robot()
        if ser:
            ser.close()